# ─── AliasingViz 3D – Quantum Engine Configuration ─────────────────
# Copy this file to .env and customize as needed.

# Provider: local_classical | qiskit_simulator | qiskit_hardware
QUANTUM_PROVIDER=local_classical

# Backend name (used with qiskit_hardware)
QUANTUM_BACKEND=aer_simulator

# Default shot count for quantum measurements
QUANTUM_SHOTS=1024

# Transpiler optimization level (0=none, 1=light, 2=medium, 3=heavy)
QUANTUM_OPTIMIZATION_LEVEL=1

# Default number of qubits
QUANTUM_NUM_QUBITS=4

# Default circuit type: phase_estimation | quantum_sampling | qft
QUANTUM_CIRCUIT_TYPE=phase_estimation

# Noise model: ideal | depolarizing | thermal
QUANTUM_NOISE_MODEL=ideal

# Noise parameters (used when noise model != ideal)
QUANTUM_SINGLE_GATE_ERROR=0.001
QUANTUM_TWO_GATE_ERROR=0.01
QUANTUM_MEASUREMENT_ERROR=0.01
QUANTUM_THERMAL_POPULATION=0.01

# IBM Quantum API token (required for qiskit_hardware provider)
# Get yours at https://quantum.ibm.com/
# QUANTUM_API_TOKEN=your_token_here

# Job management
JOB_TIMEOUT_SECONDS=60
RESULT_TTL_SECONDS=3600
MAX_RETRIES=3

# Experiment persistence
DB_PATH=experiments.db
